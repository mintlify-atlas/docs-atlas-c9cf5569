  "keyFeatures": [
    "Product browsing with featured product highlights on the homepage",
    "Category-based product filtering with size and color filters",
    "Product detail pages with image gallery and related product suggestions",
    "Persistent shopping cart using Zustand with localStorage",
    "Quick-view product preview modal",
    "Responsive design with mobile filter support",
    "Real-time toast notifications for cart actions",
    "Integration with external e-commerce API via NEXT_PUBLIC_API_URL"
  ],
  "publicApiSurface": [
    "getProducts({ categoryId?, colorId?, sizeId?, isFeatured? })",
    "getProduct(id: string)",
    "getCategories()",
    "getCategory(id: string)",
    "getBillboard(id: string)",
    "getSizes()",
    "getColors()",
    "useCart() — addItem, removeItem, removeAll",
    "usePreviewModal() — isOpen, onOpen, onClose"
  ]
